{
  "compilerOptions": {
    "resolveJsonModule": true,
    "target": "ES2019",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "allowJs": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "removeComments": true,
    "noEmitOnError": true,
    "strict": true,
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "react", "react-dom"],
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": [
    "./src/**/*.ts",
    "./src/**/*.tsx",
    "./src/**/*.d.ts",
    "src/routes/styled.ts",
    "src/index.tsx",
    "src/App.tsx",
    "src/store/modules/auth/actions.js",
    "src/pages/Page404v2/index.tsx"
  ]
}
